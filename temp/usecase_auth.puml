@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseFontSize 12
skinparam packageFontSize 14
skinparam packageFontStyle bold
skinparam usecaseBackgroundColor #E3F2FD
skinparam usecaseBorderColor #1565C0

title Sơ đồ Use Case — Xác thực & Phân quyền

actor "Nhân viên" as Staff #8BC34A
actor "Chủ quán" as Admin #FF9800
actor "Ktor Server" as Server #607D8B

rectangle "Module Xác thực" {
  usecase "Nhập Server URL" as UC1
  usecase "Nhập Username/Password" as UC2
  usecase "Gửi yêu cầu đăng nhập\n(POST /api/auth/login)" as UC3
  usecase "Xác minh mật khẩu\n(BCrypt verify)" as UC4
  usecase "Tạo JWT Token" as UC5
  usecase "Lưu session\n(SharedPreferences)" as UC6
  usecase "Kiểm tra vai trò\n(OWNER / EMPLOYEE)" as UC7
  usecase "Điều hướng đến\nEmployee Activity" as UC8
  usecase "Điều hướng đến\nAdmin Activity" as UC9
  usecase "Đăng xuất\n(Xóa token)" as UC10
  usecase "Auto-fill credentials" as UC11
}

Staff --> UC1
Staff --> UC2
Staff --> UC11
UC2 --> UC3 : <<include>>
UC3 --> Server
Server --> UC4 : <<include>>
UC4 --> UC5 : nếu hợp lệ
UC5 --> UC6 : <<include>>
UC6 --> UC7 : <<include>>
UC7 --> UC8 : role = EMPLOYEE
UC7 --> UC9 : role = OWNER

Admin --> UC2
Admin --> UC10

Staff --> UC10

@enduml
