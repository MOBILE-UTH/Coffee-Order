<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/bg_login_gradient">

    <!-- Decorative circle top-right -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="#15FFFFFF"
        android:backgroundTint="@null"
        android:elevation="0dp"
        app:layout_collapseMode="none">
        <!-- drawn as circle via code; plain view for bg -->
    </View>

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-40dp"
        android:layout_marginBottom="-40dp"
        android:background="#10FFFFFF" />

    <!-- Main scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="72dp"
            android:paddingEnd="28dp"
            android:paddingBottom="48dp">

            <!-- ── Logo area ─────────────────────────────── -->
            <FrameLayout
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp">

                <!-- Circle glow -->
                <View
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_logo_circle" />

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/coffee_logo"
                    android:src="@drawable/ic_coffee_cup" />
            </FrameLayout>

            <!-- App name -->
            <TextView
                android:id="@+id/textViewTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:text="@string/coffee_order"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/textViewSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="40dp"
                android:fontFamily="sans-serif-light"
                android:text="@string/qu_n_l_th_ng_minh_ph_c_v_ho_n_h_o"
                android:textColor="#AAFFFFFF"
                android:textSize="13sp" />

            <!-- ── Glass card form ───────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Card title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/ng_nh_p"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Server URL field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:text="@string/a_ch_server"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@string/server_icon"
                        android:src="@drawable/ic_wifi" />

                    <EditText
                        android:id="@+id/editTextServer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:autofillHints=""
                        android:background="@null"
                        android:hint="@string/http_192_168_x_x_8080"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:text="@string/http_192_168_10_72_8080"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Username field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:text="@string/t_n_ng_nh_p"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_glass"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@string/user_icon"
                        android:src="@drawable/ic_user" />

                    <EditText
                        android:id="@+id/editTextUsername"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:autofillHints="username"
                        android:importantForAutofill="yes"
                        android:background="@null"
                        android:hint="@string/nh_p_t_n_ng_nh_p"
                        android:inputType="text"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Password field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:text="@string/m_t_kh_u"
                    android:textColor="#99FFFFFF"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_input_glass"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="@string/lock_icon"
                        android:src="@drawable/ic_lock" />

                    <EditText
                        android:id="@+id/editTextPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:autofillHints="password"
                        android:importantForAutofill="yes"
                        android:background="@null"
                        android:hint="@string/nh_p_m_t_kh_u"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="@string/hi_n_m_t_kh_u"
                        android:focusable="true"
                        android:src="@drawable/ic_visibility" />
                </LinearLayout>

                <!-- Error message -->
                <TextView
                    android:id="@+id/textViewError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:paddingStart="12dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="8dp"
                    android:textColor="#FFCDD2"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Login button -->
                <Button
                    android:id="@+id/buttonLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_btn_login"
                    android:elevation="4dp"
                    android:letterSpacing="0.1"
                    android:stateListAnimator="@null"
                    android:text="@string/ng_nh_p"
                    android:textColor="#3D1C08"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:indeterminateTint="#E8B88A"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/_2026_coffee_order_system"
                android:textColor="#55FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
